# Gaia API — development environment configuration.
# Secrets are never stored in code (Vol 6 §9.6); production uses a secret manager.
PORT=4000
DATABASE_URL=postgres://gaia:gaia@localhost:5432/gaia
REDIS_URL=redis://localhost:6379
# JWT signing secret — dev only. Rotate and store in Vault/Secrets Manager in prod.
JWT_SECRET=dev-secret-change-me
# Access tokens are short-lived (15 min); refresh tokens long-lived (30 days). Vol 6 §5.4.
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
